{
  "version": 2,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.3"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ],
  "env": {
    "APP_ENV": "production",
    "APP_DEBUG": "false",
    "APP_STORAGE": "/tmp/storage",
    "VIEW_COMPILED_PATH": "/tmp/views",
    "CACHE_DRIVER": "file",
    "SESSION_DRIVER": "file"
  }
}